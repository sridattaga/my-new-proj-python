pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "sridatta5157/python-devops-app:${BUILD_NUMBER}"
        RECIPIENTS = "sridatta1971@gmail.com"
    }

    stages {

        stage('Clone') {
            steps {
                git branch: 'main',
                    credentialsId: 'jenkinskey',
                    url: 'https://github.com/sridattaga/my-new-proj-python.git'
            }
        }

        stage('Build App') {
            steps {
                sh '''
                pip3 install -r requirements.txt
                python3 setup.py bdist_wheel
                '''
            }
        }

        stage('Docker Build & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dock_CRED',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh '''
                    docker build -t $DOCKER_IMAGE .
                    echo $PASS | docker login -u $USER --password-stdin
                    docker push $DOCKER_IMAGE
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                kubectl apply -f k8s/
                '''
            }
        }

        stage('Verify') {
            steps {
                sh '''
                kubectl get pods
                kubectl get svc
                '''
            }
        }
    }

    post {
        success {
            emailext subject: "SUCCESS",
                     body: "Pipeline Success: ${BUILD_URL}",
                     to: "${RECIPIENTS}"
        }
        failure {
            emailext subject: "FAILED",
                     body: "Pipeline Failed: ${BUILD_URL}",
                     to: "${RECIPIENTS}"
        }
    }
}
